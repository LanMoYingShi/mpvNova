<?xml version="1.0" encoding="utf-8"?>
<!-- Skip Intro/Outro/Recap pill. Uses the same translucent overlay gradient as the player
     controls bar (bg_player_controls) so it reads as see-through like the rest of the UI. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="?attr/mpvFocusWashSoft" />
                    <stroke
                        android:width="2dp"
                        android:color="?attr/mpvStrokeFocus" />
                    <corners android:radius="18dp" />
                </shape>
            </item>
            <item
                android:bottom="3dp"
                android:left="3dp"
                android:right="3dp"
                android:top="3dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="270"
                        android:startColor="?attr/mpvOverlayStart"
                        android:centerColor="?attr/mpvOverlayCenter"
                        android:endColor="?attr/mpvOverlayEnd"
                        android:type="linear" />
                    <stroke
                        android:width="1dp"
                        android:color="?attr/mpvStrokeStrong" />
                    <corners android:radius="15dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:startColor="?attr/mpvOverlayStart"
                android:centerColor="?attr/mpvOverlayCenter"
                android:endColor="?attr/mpvOverlayEnd"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="?attr/mpvStroke" />
            <corners android:radius="15dp" />
        </shape>
    </item>
</selector>
