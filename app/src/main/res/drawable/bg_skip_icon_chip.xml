<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="oval">
                    <solid android:color="?attr/mpvFocusWashSoft" />
                    <stroke
                        android:width="2dp"
                        android:color="?attr/mpvStrokeFocus" />
                </shape>
            </item>
            <item
                android:bottom="3dp"
                android:left="3dp"
                android:right="3dp"
                android:top="3dp">
                <shape android:shape="oval">
                    <gradient
                        android:angle="270"
                        android:endColor="?attr/mpvChipEnd"
                        android:startColor="?attr/mpvChipStart"
                        android:type="linear" />
                    <stroke
                        android:width="1dp"
                        android:color="?attr/mpvStrokeStrong" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="270"
                android:endColor="?attr/mpvChipEnd"
                android:startColor="?attr/mpvChipStart"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="?attr/mpvStrokeStrong" />
        </shape>
    </item>
</selector>
