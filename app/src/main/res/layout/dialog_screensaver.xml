<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tv_dialog_shell"
    android:elevation="24dp"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="20dp"
    android:paddingEnd="22dp"
    android:paddingBottom="18dp">

    <TextView
        style="@style/MpvTv.TextSmallCaps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/option_picker_playback"
        android:textColor="?attr/mpvAccentHot" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:letterSpacing="0"
        android:singleLine="true"
        android:text="@string/pref_screensaver_title"
        android:textColor="@color/tv_text"
        android:textSize="24sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        android:layout_weight="1"
        android:background="@drawable/bg_tv_panel_card"
        android:clipChildren="true"
        android:clipToOutline="true"
        tools:targetApi="s">

        <ScrollView
            android:id="@+id/screensaverScroll"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:fillViewport="false"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="12dp"
            android:scrollbarDefaultDelayBeforeFade="1200"
            android:scrollbarFadeDuration="240"
            android:scrollbarSize="3dp"
            android:scrollbarStyle="insideInset"
            android:scrollbarThumbVertical="@drawable/bg_tv_scrollbar_thumb"
            android:scrollbarTrackVertical="@drawable/bg_tv_scrollbar_track"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingEnd="8dp">

                <TextView
                    style="@style/MpvTv.TextSmallCaps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:layout_marginBottom="2dp"
                    android:text="@string/pref_screensaver_mode_header"
                    android:textColor="@color/tv_text_dim" />

                <LinearLayout
                    android:id="@+id/screensaverModeRows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <TextView
                    style="@style/MpvTv.TextSmallCaps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="2dp"
                    android:text="@string/pref_screensaver_idle_header"
                    android:textColor="@color/tv_text_dim" />

                <LinearLayout
                    android:id="@+id/screensaverTimeoutRows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <LinearLayout
                    android:id="@+id/screensaverLogoSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/MpvTv.TextSmallCaps"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="2dp"
                        android:text="@string/pref_screensaver_logo_header"
                        android:textColor="@color/tv_text_dim" />

                    <LinearLayout
                        android:id="@+id/screensaverLogoRows"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/screensaverDoneBtn"
            style="@style/Mpv.SurfaceButton"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:minWidth="76dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/dialog_done" />
    </LinearLayout>
</LinearLayout>
