<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_tv_dialog_shell"
    android:elevation="24dp"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="20dp"
    android:paddingEnd="22dp"
    android:paddingBottom="18dp">

    <TextView
        style="@style/MpvTv.TextSmallCaps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/advanced_menu_title"
        android:textColor="?attr/mpvAccentHot" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:letterSpacing="0"
        android:singleLine="true"
        android:text="@string/audio_delay"
        android:textColor="@color/tv_text"
        android:textSize="24sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_tv_panel_card"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_tv_track_row"
            android:minHeight="62dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/audio_delay_current"
                    android:textColor="@color/tv_text"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/audio_delay_step_hint"
                    android:textColor="@color/tv_text_dim"
                    android:textSize="10sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/audioDelayMinusBtn"
                style="@style/MpvPlayer.ButtonBarIconButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center_vertical"
                android:contentDescription="@string/btn_decrease"
                android:minWidth="36dp"
                android:minHeight="36dp"
                app:srcCompat="@drawable/ic_remove_24dp"
                app:tint="@color/tv_text" />

            <TextView
                android:id="@+id/audioDelayCurrentValue"
                android:layout_width="86dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:gravity="center"
                android:textColor="@color/tv_text"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="+25 ms" />

            <ImageButton
                android:id="@+id/audioDelayPlusBtn"
                style="@style/MpvPlayer.ButtonBarIconButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="center_vertical"
                android:contentDescription="@string/btn_increase"
                android:minWidth="36dp"
                android:minHeight="36dp"
                app:srcCompat="@drawable/ic_add_24dp"
                app:tint="@color/tv_text" />
        </LinearLayout>

        <Button
            android:id="@+id/audioDelayResetBtn"
            style="@style/Mpv.SurfaceButton.Compact"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:text="@string/dialog_reset" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@color/tv_stroke" />

        <TextView
            android:id="@+id/audioDelayRememberSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/tv_text_dim"
            android:textSize="11sp"
            tools:text="Remembered delay: +25 ms" />

        <Button
            android:id="@+id/audioDelayRememberBtn"
            style="@style/Mpv.SurfaceButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:text="@string/audio_delay_remember" />

        <Button
            android:id="@+id/audioDelayClearRememberBtn"
            style="@style/Mpv.SurfaceButton.Compact"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:text="@string/audio_delay_clear_remembered" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@color/tv_stroke" />

        <TextView
            android:id="@+id/audioDelayBtSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/tv_text_dim"
            android:textSize="11sp"
            tools:text="Bluetooth delay: +100 ms" />

        <Button
            android:id="@+id/audioDelayApplyBtBtn"
            style="@style/Mpv.SurfaceButton"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:text="@string/audio_delay_apply_bt" />

        <Button
            android:id="@+id/audioDelayClearBtBtn"
            style="@style/Mpv.SurfaceButton.Compact"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:text="@string/audio_delay_clear_bt" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/audioDelayCloseBtn"
            style="@style/Mpv.SurfaceButton"
            android:layout_width="wrap_content"
            android:layout_height="42dp"
            android:minWidth="76dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/update_close" />
    </LinearLayout>
</LinearLayout>
