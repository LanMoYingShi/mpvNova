<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_tv_dialog_shell"
    android:elevation="24dp"
    android:orientation="vertical"
    android:paddingStart="28dp"
    android:paddingTop="26dp"
    android:paddingEnd="28dp"
    android:paddingBottom="26dp">

    <TextView
        style="@style/MpvTv.TextSmallCaps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/mpv_activity"
        android:textColor="?attr/mpvAccentHot" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:singleLine="true"
        android:text="@string/player_menu"
        android:textColor="@color/tv_text"
        android:textSize="28sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_tv_panel_card"
        android:orientation="horizontal">

        <Button
            android:id="@+id/audioBtn"
            style="@style/Mpv.SurfaceButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"
            android:layout_weight="1"
            android:text="@string/open_external_audio"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/subBtn"
            style="@style/Mpv.SurfaceButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp"
            android:layout_weight="1"
            android:text="@string/open_external_sub"
            android:textAllCaps="false" />
    </LinearLayout>

    <Button
        android:id="@+id/playlistBtn"
        style="@style/Mpv.SurfaceButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/action_playlist"
        android:textAllCaps="false" />

    <Button
        android:id="@+id/backgroundBtn"
        style="@style/Mpv.SurfaceButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/resume_bg_playback"
        android:textAllCaps="false" />

    <LinearLayout
        android:id="@+id/rowChapter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/chapterBtn"
            style="@style/Mpv.SurfaceButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="4"
            android:text="@string/chapter_button"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/chapterPrev"
            style="@style/Mpv.SurfaceButton.Compact"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/dialog_prev"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/chapterNext"
            style="@style/Mpv.SurfaceButton.Compact"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/dialog_next"
            android:textAllCaps="false" />

    </LinearLayout>

    <Button
        android:id="@+id/advancedBtn"
        style="@style/Mpv.SurfaceButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/advanced_menu"
        android:textAllCaps="false" />

</LinearLayout>
