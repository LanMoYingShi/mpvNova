<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_tv_dialog_shell"
    android:elevation="24dp"
    android:orientation="vertical"
    android:paddingStart="28dp"
    android:paddingTop="26dp"
    android:paddingEnd="28dp"
    android:paddingBottom="22dp">

    <TextView
        style="@style/MpvTv.TextSmallCaps"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sub_style_title"
        android:textColor="?attr/mpvAccentHot" />

    <TextView
        android:id="@+id/presetDialogTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:letterSpacing="0"
        android:singleLine="true"
        android:textColor="@color/tv_text"
        android:textSize="28sp"
        android:textStyle="bold"
        tools:text="Save preset" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_tv_panel_card"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="18dp"
        android:paddingEnd="16dp"
        android:paddingBottom="18dp">

        <EditText
            android:id="@+id/presetNameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/sub_style_preset_name_hint"
            android:importantForAutofill="no"
            android:inputType="textCapSentences"
            android:maxLength="12"
            android:maxLines="1"
            android:singleLine="true"
            android:textColor="@color/tv_text"
            android:textColorHint="@color/tv_text_dim"
            android:textSize="18sp"
            tools:ignore="LabelFor" />

        <TextView
            android:id="@+id/presetNameCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="end"
            android:textColor="@color/tv_text_dim"
            android:textSize="11sp"
            tools:text="0/12" />

        <LinearLayout
            android:id="@+id/presetIncludeLayoutRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_tv_track_row"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="64dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sub_style_preset_include_layout"
                    android:textColor="@color/tv_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/sub_style_preset_include_layout_summary"
                    android:textColor="@color/tv_text_dim"
                    android:textSize="11sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/presetIncludeLayoutCheck"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:contentDescription="@string/sub_style_preset_include_layout"
                android:src="@drawable/ic_tv_check"
                android:visibility="invisible"
                app:tint="@color/tv_text"
                tools:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/presetOverrideAssRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_tv_track_row"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="64dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sub_style_override_ass"
                    android:textColor="@color/tv_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/sub_style_override_ass_summary"
                    android:textColor="@color/tv_text_dim"
                    android:textSize="11sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/presetOverrideAssCheck"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:contentDescription="@string/sub_style_override_ass"
                android:src="@drawable/ic_tv_check"
                android:visibility="invisible"
                app:tint="@color/tv_text"
                tools:visibility="visible" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/presetForceAllRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_tv_track_row"
            android:clickable="true"
            android:focusable="true"
            android:minHeight="64dp"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sub_style_force_all_ass"
                    android:textColor="@color/tv_text"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/sub_style_force_all_ass_summary"
                    android:textColor="@color/tv_text_dim"
                    android:textSize="11sp" />
            </LinearLayout>

            <ImageView
                android:id="@+id/presetForceAllCheck"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="12dp"
                android:contentDescription="@string/sub_style_force_all_ass"
                android:src="@drawable/ic_tv_check"
                android:visibility="invisible"
                app:tint="@color/tv_text"
                tools:visibility="visible" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="end"
        android:orientation="horizontal">

        <Button
            android:id="@+id/presetCancelBtn"
            style="@style/Mpv.SurfaceButton.Compact"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:minWidth="84dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/dialog_cancel" />

        <Button
            android:id="@+id/presetSaveBtn"
            style="@style/Mpv.SurfaceButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:minWidth="84dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/dialog_save" />
    </LinearLayout>
</LinearLayout>
